#!/bin/sh
# ox developer pre-commit hook
#
# Scope: This hook is for ox contributors ONLY. It is NOT installed into
#        user repos. It runs fast lint checks on staged files before commit.
#
# Target: <2 sec total. Thorough checks (golangci-lint, tests) run in CI.
#
# Install: make install-hooks
#          (copies this file to .git/hooks/pre-commit)

set -e

# --- 0. Git identity guard (<50ms) ---
# Block commits from test identities that leak from running tests
GIT_NAME=$(git config user.name 2>/dev/null || echo "")
GIT_EMAIL=$(git config user.email 2>/dev/null || echo "")

# Block empty values
if [ -z "$GIT_NAME" ] || [ -z "$GIT_EMAIL" ]; then
    echo "ERROR: Git identity not configured"
    echo "  user.name = '$GIT_NAME'"
    echo "  user.email = '$GIT_EMAIL'"
    echo ""
    echo "Fix with:"
    echo "  git config user.name 'Your Real Name'"
    echo "  git config user.email 'your@email.com'"
    exit 1
fi

# Block any name/email containing "test" (case-insensitive)
GIT_NAME_LOWER=$(echo "$GIT_NAME" | tr '[:upper:]' '[:lower:]')
GIT_EMAIL_LOWER=$(echo "$GIT_EMAIL" | tr '[:upper:]' '[:lower:]')

if echo "$GIT_NAME_LOWER" | grep -q "test"; then
    echo "ERROR: Git user.name contains 'test' - likely corrupted by a test"
    echo "  user.name = '$GIT_NAME'"
    echo ""
    echo "A test likely corrupted your git config. Fix with:"
    echo "  git config user.name 'Your Real Name'"
    exit 1
fi

if echo "$GIT_EMAIL_LOWER" | grep -q "test"; then
    echo "ERROR: Git user.email contains 'test' - likely corrupted by a test"
    echo "  user.email = '$GIT_EMAIL'"
    echo ""
    echo "A test likely corrupted your git config. Fix with:"
    echo "  git config user.email 'your@email.com'"
    exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_GO_FILES=$(echo "$STAGED_FILES" | grep '\.go$' || true)

# --- 1. Merge conflict markers (<100ms) ---
if [ -n "$STAGED_FILES" ]; then
    if echo "$STAGED_FILES" | xargs grep -l '^<<<<<<<\|^>>>>>>>\|^=======$' 2>/dev/null; then
        echo "Error: Merge conflict markers found in staged files"
        exit 1
    fi
fi

# --- 2. Large file guard (<100ms) ---
MAX_SIZE=1048576  # 1MB
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        size=$(wc -c < "$file")
        if [ "$size" -gt "$MAX_SIZE" ]; then
            echo "Error: $file is $(($size / 1024))KB (max 1MB)"
            echo "Use git lfs or add to .gitignore"
            exit 1
        fi
    fi
done

# --- 3. YAML syntax (<100ms) ---
STAGED_YAML=$(echo "$STAGED_FILES" | grep -E '\.(ya?ml)$' || true)
if [ -n "$STAGED_YAML" ] && command -v yq >/dev/null 2>&1; then
    for file in $STAGED_YAML; do
        if ! yq e '.' "$file" >/dev/null 2>&1; then
            echo "Error: Invalid YAML syntax in $file"
            exit 1
        fi
    done
fi

# --- 4. Go checks ---
if [ -n "$STAGED_GO_FILES" ]; then
    # gofmt (<200ms)
    UNFORMATTED=$(echo "$STAGED_GO_FILES" | xargs gofmt -l 2>/dev/null || true)
    if [ -n "$UNFORMATTED" ]; then
        echo "Unformatted Go files:"
        echo "$UNFORMATTED"
        echo ""
        echo "Run: make format"
        exit 1
    fi

    # go vet on affected packages (<500ms)
    # Extract unique package directories from staged files
    STAGED_PKGS=$(echo "$STAGED_GO_FILES" | xargs -n1 dirname | sort -u | sed 's|^|./|')
    if [ -n "$STAGED_PKGS" ]; then
        echo "$STAGED_PKGS" | xargs go vet 2>&1 || {
            echo ""
            echo "go vet found issues. Fix before committing."
            exit 1
        }
    fi
fi

# --- 5. Secrets scan (~500ms) ---
if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --no-banner 2>/dev/null; then
        echo ""
        echo "Potential secrets detected. Review above or use --no-verify to bypass."
        exit 1
    fi
fi

# --- 6. Beads sync (<200ms) ---
# bd-hooks-version: 0.29.0

if command -v bd >/dev/null 2>&1 && [ -d .beads ]; then
    SYNC_BRANCH="${BEADS_SYNC_BRANCH:-}"
    if [ -z "$SYNC_BRANCH" ] && [ -f .beads/config.yaml ]; then
        SYNC_BRANCH=$(grep -E '^sync-branch:' .beads/config.yaml 2>/dev/null | head -1 | sed 's/^sync-branch:[[:space:]]*//' | sed 's/^["'"'"']//' | sed 's/["'"'"']$//')
    fi

    if [ -z "$SYNC_BRANCH" ]; then
        bd sync --flush-only >/dev/null 2>&1 || true
        for f in .beads/beads.jsonl .beads/issues.jsonl .beads/deletions.jsonl; do
            [ -f "$f" ] && git add "$f" 2>/dev/null || true
        done
    fi
fi

exit 0
